{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/salute-developers/plasma-ios/release-manifest.schema.json",
  "title": "Plasma iOS Release Manifest",
  "description": "Machine-readable manifest for client sync scripts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generatedAt",
    "sourceRepo",
    "libraries"
  ],
  "properties": {
    "generatedAt": {
      "type": "string",
      "description": "UTC timestamp in ISO-8601 format",
      "format": "date-time"
    },
    "sourceRepo": {
      "type": "string",
      "description": "Source repository in owner/name format",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "libraries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "assetFileName",
          "downloadUrl",
          "releaseTag"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "assetFileName": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+\\.zip$"
          },
          "downloadUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://github\\.com/.+/releases/download/.+/.+\\.zip$"
          },
          "releaseTag": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
